<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.oref.alerts.keepalive</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/anna/.openclaw/workspace/oref-api/keep-alive.sh</string>
    </array>
    
    <key>StartInterval</key>
    <integer>600</integer> <!-- 600 seconds = 10 minutes -->
    
    <key>RunAtLoad</key>
    <true/>
    
    <key>StandardOutPath</key>
    <string>/Users/anna/.openclaw/workspace/oref-api/keepalive-launchd.log</string>
    
    <key>StandardErrorPath</key>
    <string>/Users/anna/.openclaw/workspace/oref-api/keepalive-launchd-error.log</string>
    
    <key>WorkingDirectory</key>
    <string>/Users/anna/.openclaw/workspace/oref-api</string>
</dict>
</plist>