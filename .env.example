# Server Configuration
PORT=3000
NODE_ENV=development

# Cache Configuration
CACHE_TTL_CURRENT=30      # Cache current alerts for 30 seconds
CACHE_TTL_HISTORY=300     # Cache history for 5 minutes
CACHE_ENABLED=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000    # 1 minute window
RATE_LIMIT_MAX_REQUESTS=100   # Max requests per window
WS_MAX_CONNECTIONS_PER_IP=10  # Max WebSocket connections per IP

# Logging
LOG_LEVEL=info              # debug, info, warn, error
LOG_REQUESTS=true

# API Timeouts
API_TIMEOUT_MS=10000        # 10 second timeout for Oref API
API_RETRY_ATTEMPTS=3        # Number of retry attempts
API_RETRY_DELAY_MS=1000     # Delay between retries in ms

# Security
CORS_ORIGIN=*               # CORS origin, use specific domain in production
HELMET_ENABLED=true         # Enable security headers

# Monitoring
HEALTH_CHECK_INTERVAL_MS=30000  # Health check interval
METRICS_ENABLED=true            # Enable metrics collection

# WebSocket
WS_POLL_INTERVAL_MS=5000    # Poll interval for WebSocket updates
WS_MAX_PAYLOAD_SIZE=1048576 # 1MB max WebSocket payload

# Development
DEBUG=false                 # Enable debug mode
HOT_RELOAD=true             # Enable hot reload in development